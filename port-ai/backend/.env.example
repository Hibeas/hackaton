# Supabase PostgreSQL (required — no silent SQLite fallback when set)
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.jqmdskafhpbppgfrekxs.supabase.co:5432/postgres
DATABASE_CONNECT_TIMEOUT_SEC=10
DATABASE_URL=

# JWT auth (required for /api/v1/auth/*)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080

# TomTom — uncomment only with your own key (dev fallback exists in code).
# TOMTOM_API_KEY=

# Kafka — start broker: cd port-ai && docker compose up -d
KAFKA_BOOTSTRAP_SERVERS=localhost:8081
KAFKA_TOPIC=port-traffic-events
KAFKA_PUBLISH_ON_REFRESH=true
KAFKA_CONSUMER_ENABLED=true
KAFKA_CONSUMER_GROUP=port-ai-forecast
KAFKA_PREDICTION_BUFFER_MINUTES=30

# ML delay forecast (Random Forest, long horizon >30 min)
TRAFFIC_ML_ENABLED=true
TRAFFIC_ML_MODEL_PATH=data/ml/traffic_delay_regressor.pkl

# Voice alerts — ElevenLabs Conversational AI + Twilio (optional)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_NUMBER=+1234567890
# ELEVENLABS_API_KEY=
# ELEVENLABS_AGENT_ID=
# ELEVENLABS_CALL_LANGUAGE=pl
# VOICE_CALL_DEMO_TO=+48123456789
# VOICE_CALL_MODE=say
#   agent — ElevenLabs convai (first_message override)
#   say   — Twilio <Say> pl-PL (exact text, hackathon-safe)
# Public URL for Twilio status webhooks (ngrok or deployed backend)
# PUBLIC_API_BASE_URL=https://your-subdomain.ngrok-free.app
# TWILIO_STATUS_CALLBACK_URL=https://your-subdomain.ngrok-free.app/api/v1/voice/twilio/status
# TWILIO_VALIDATE_WEBHOOK=true

# Slot dispatch — forecast → gate slots (mock TMS) → auto-call speditions
SLOT_DISPATCH_AUTO_ENABLED=true
SLOT_DISPATCH_MIN_DELAY_SEC=600
SLOT_DISPATCH_MIN_HORIZON_MIN=30
SLOT_DISPATCH_CALL_COOLDOWN_MIN=45
SLOT_DISPATCH_LOOKAHEAD_MIN=180
